<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="25dp">

    <CheckBox
        android:id="@+id/chkSelectItem"
        android:layout_width="36dp"
        android:layout_height="35dp"
        android:layout_gravity="center_vertical"
        android:checked="true" />

    <ImageView
        android:id="@+id/imgProduct"
        android:layout_width="95dp"
        android:layout_height="95dp"
        android:layout_gravity="center_vertical"
        android:layout_weight="1"
        app:srcCompat="@drawable/product_photo" />

    <LinearLayout
        android:layout_width="150dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center_vertical"
        android:layout_marginLeft="10dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/txtProductTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="@font/poppins"
            android:inputType="text"
            android:text="Trung Thanh Duy Ai"
            android:textColor="#391319"
            android:textSize="11dp" />

        <LinearLayout
            android:id="@+id/sales"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/txtDiscountedPrice"
                android:layout_width="80dp"
                android:layout_height="wrap_content"
                android:ems="10"
                android:fontFamily="@font/poppins_bold"
                android:inputType="text"
                android:text="75,00$"
                android:textColor="#C92127"
                android:textSize="14dp" />

            <androidx.cardview.widget.CardView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="#C92127"
                app:cardCornerRadius="4dp"
                app:cardElevation="6dp">

                <TextView
                    android:id="@+id/txtSale"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_margin="2dp"
                    android:layout_weight="1"
                    android:background="#C92127"
                    android:fontFamily="@font/poppins"
                    android:gravity="center"
                    android:paddingStart="5dp"
                    android:paddingEnd="5dp"
                    android:text="-30%"
                    android:textColor="#FDFDFD"
                    android:textSize="10dp" />
            </androidx.cardview.widget.CardView>

        </LinearLayout>

        <TextView
            android:id="@+id/txtOrgPrice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:ems="10"
            android:fontFamily="@font/poppins"
            android:inputType="text"
            android:text="50,00$"
            android:textColor="#A8A8A9"
            android:textSize="11dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="start"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/btnMinus"
                android:layout_width="20dp"
                android:layout_height="20dp"
                app:srcCompat="@drawable/ic_minus" />

            <TextView
                android:id="@+id/txtBookQuantity"
                android:layout_width="40dp"
                android:layout_height="wrap_content"
                android:ems="3"
                android:fontFamily="@font/poppins_semibold"
                android:inputType="number"
                android:textAlignment="center"
                android:textSize="13dp" />

            <ImageView
                android:id="@+id/btnPlus"
                android:layout_width="20dp"
                android:layout_height="20dp"
                app:srcCompat="@drawable/ic_plus" />
        </LinearLayout>

    </LinearLayout>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/imgAddToWishlist"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_weight="1"
            app:srcCompat="@drawable/ic_wishlist" />

        <ImageView
            android:id="@+id/imgDeleteItem"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            app:srcCompat="@drawable/ic_bin" />


    </LinearLayout>

</LinearLayout>