<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:id="@+id/imgEvent"
        android:layout_width="120dp"
        android:layout_height="120dp"
        app:srcCompat="@drawable/event" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="30dp">

        <TextView
            android:id="@+id/txtEventName"
            android:layout_width="198dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="11dp"
            android:fontFamily="@font/poppins_semibold"
            android:text="Tom Green: Meet &amp; Signing in Vietnam"
            android:textSize="14dp" />
        <View
            android:layout_width="0dp"
            android:layout_height="14dp"/>

        <TableLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TableRow
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/imgStatusDot"
                    android:layout_width="6dp"
                    android:layout_height="6dp"
                    app:srcCompat="@drawable/ic_ellipse_green"
                    android:layout_marginEnd="10dp"/>

                <TextView
                    android:id="@+id/txtEventStatus"
                    android:layout_width="194dp"
                    android:layout_height="wrap_content"
                    android:text="Open for Registration"
                    android:fontFamily="@font/poppins"
                    android:textSize="10dp"/>
            </TableRow>

            <TableRow
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/imageView4"
                    android:layout_width="10dp"
                    android:layout_height="12dp"
                    app:srcCompat="@drawable/ic_address"
                    android:layout_marginEnd="10dp"/>

                <TextView
                    android:id="@+id/txtEventLoc"
                    android:layout_width="194dp"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/poppins"
                    android:text="Youth Cultural House - 4 Phạm Ngọc Thạch, Bến Nghé, Quận 1, Hồ Chí Minh "
                    android:textSize="10dp" />
            </TableRow>
            <TableRow
                android:layout_width="match_parent"
                android:layout_height="match_parent" android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/imageView7"
                    android:layout_width="10dp"
                    android:layout_height="9dp"
                    app:srcCompat="@drawable/ic_calendar"
                    android:layout_marginEnd="10dp"/>

                <TextView
                    android:id="@+id/txtEventStart"
                    android:layout_width="194dp"
                    android:layout_height="wrap_content"
                    android:text="June 30, 2025"
                    android:fontFamily="@font/poppins"
                    android:textSize="10dp"/>
            </TableRow>
            <TableRow
                android:layout_width="match_parent"
                android:layout_height="match_parent" />
        </TableLayout>

    </LinearLayout>
</LinearLayout>