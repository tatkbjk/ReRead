<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".activity.EventDetailActivity">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/green"
        android:orientation="vertical">

        <!-- LOGO + THANH TÌM KIẾM + ICON -->
        <ImageView
            android:id="@+id/imgLogo"
            app:srcCompat="@drawable/ic_logo_white"
            android:layout_width="100dp"
            android:layout_height="40dp"
            android:layout_gravity="center"
            android:layout_marginTop="5dp"
            android:layout_marginBottom="5dp" />
        <!-- mỗi cái ImageView sẽ có onClick nữa nhưng tính sau -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/constraintLayout2"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="10dp">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/imgGroup"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_marginStart="24dp"
                android:layout_marginTop="5dp"
                android:padding="0dp"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_group" />

            <SearchView
                android:id="@+id/searchBar"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="1.0"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:queryBackground="@android:color/transparent"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_marginStart="70dp"
                android:layout_marginEnd="120dp"
                android:background="@drawable/ic_largebar"
                android:iconifiedByDefault="false"
                android:searchIcon="@drawable/ic_search"/>

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/imgCart"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_marginStart="310dp"
                android:layout_marginTop="5dp"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_cart" />

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/imgProfile"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_marginStart="360dp"
                android:layout_marginTop="5dp"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_profile" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/imgEventDetail"
                android:layout_width="match_parent"
                android:layout_height="221dp"
                app:srcCompat="@drawable/event_detail" />

            <!-- PICKED FOR YOU SECTION -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:paddingStart="32dp"
                android:paddingEnd="32dp">

                <TextView
                    android:id="@+id/txtEventName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:fontFamily="@font/poppins_semibold"
                    android:text="Tom Green: Meet &amp; Signing in Vietnam"
                    android:textSize="18dp" />

                <TextView
                    android:id="@+id/txtEventDate"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="5dp"
                    android:fontFamily="@font/poppins"
                    android:text="🗓 Date: July 15, 2025"
                    android:textSize="11dp" />

                <TextView
                    android:id="@+id/txtEventTime"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/poppins"
                    android:text="🕐 Time: 13:00 – 17:00"
                    android:textSize="11dp" />

                <TextView
                    android:id="@+id/txtEventLoc"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/poppins"
                    android:text="📍 Location: Youth Cultural House – 4 Phạm Ngọc Thạch, Bến Nghé, District 1, Ho Chi Minh City"
                    android:textSize="11dp" />

                <TextView
                    android:id="@+id/txtEventDesc"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="5dp"
                    android:fontFamily="@font/poppins"
                    android:text="Get ready for an unforgettable evening as Canadian comedian, actor, and filmmaker Tom Green makes his way to Vietnam for a special Meet &amp; Signing event!
            \n Whether you know him from The Tom Green Show, Road Trip, or his stand-up comedy, this is your chance to meet Tom Green up close, hear stories from his career, and get your favorite merch or memorabilia signed in person.
            \n👉 Click &quot;Register&quot; now to secure your spot!
            \nWe can’t wait to see you there! "
                    android:textSize="11dp" />

                <Button
                    android:id="@+id/btnRegister"
                    android:layout_width="190dp"
                    android:layout_height="56dp"
                    android:layout_gravity="center"
                    android:layout_marginTop="15dp"
                    android:backgroundTint="#0A7B41"
                    android:fontFamily="@font/poppins"
                    android:text="@string/title_btn_register"
                    android:textSize="15dp"
                    app:cornerRadius="0dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/lightgreen"
                android:orientation="vertical"
                android:paddingBottom="8dp"
                android:layout_marginTop="20dp">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <ImageView
                        android:id="@+id/imgLargeBar1"
                        android:layout_width="350dp"
                        android:layout_height="40dp"
                        android:layout_marginStart="30dp"
                        android:layout_marginTop="10dp"
                        android:layout_marginBottom="10dp"
                        app:srcCompat="@drawable/ic_largebar" />

                    <ImageView
                        android:id="@+id/imgStar"
                        android:layout_width="18dp"
                        android:layout_height="20dp"
                        android:layout_marginStart="40dp"
                        android:layout_marginTop="17.5dp"
                        android:layout_marginBottom="10dp"
                        app:srcCompat="@drawable/ic_park_solid_other" />

                    <TextView
                        android:id="@+id/txtPickedForYou"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="80dp"
                        android:layout_marginTop="19dp"
                        android:fontFamily="@font/poppins_semibold_italic"
                        android:text="@string/title_other_events"
                        android:textColor="@color/green"
                        android:textSize="16sp" />
                    <ImageView
                        android:id="@+id/imgMorePickedForYou"
                        android:layout_width="15dp"
                        android:layout_height="15dp"
                        android:layout_marginStart="355dp"
                        android:layout_marginTop="22dp"
                        android:layout_marginBottom="10dp"
                        app:srcCompat="@drawable/ic_more" />
                </FrameLayout>
                <!-- cái này là dùng cho cái phần hiển thị picked-->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvOtherEvent"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:clipToPadding="false"
                    android:scrollbars="none" />

            </LinearLayout>
        </LinearLayout>

    </ScrollView>
</LinearLayout>

