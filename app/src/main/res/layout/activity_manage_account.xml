<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    tools:context=".activity.ManageAccountActivity"
    android:background="#ffffff">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar2"
        android:layout_width="match_parent"
        android:layout_height="87dp"
        android:background="#0A7B41"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="32dp">

            <ImageView
                android:id="@+id/imageView4"
                android:layout_width="89dp"
                android:layout_height="17dp"
                android:layout_gravity="center"
                android:layout_margin="15dp"
                app:srcCompat="@drawable/ic_logo" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="horizontal"
                android:padding="8dp"
                android:layout_marginBottom="5dp">

                <!-- Icon bên trái -->
                <ImageView
                    android:id="@+id/imageView5"
                    android:layout_width="24dp"
                    android:layout_height="24dp"

                    app:srcCompat="@drawable/ic_back" />

                <!-- View trống để đẩy icon bên phải về cuối -->
                <TextView
                    android:id="@+id/textView40"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="5dp"
                    android:layout_weight="1"
                    android:fontFamily="@font/poppins_semibold"
                    android:text="@string/title_my_profile"
                    android:textColor="#ffffff" />

                <!-- Icon bên phải -->
                <ImageView
                    android:id="@+id/imageView7"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    app:srcCompat="@drawable/ic_cart_white" />
            </LinearLayout>
        </LinearLayout>
    </androidx.appcompat.widget.Toolbar>
    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/toolbar2"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:orientation="horizontal"
                android:paddingStart="32dp"
                android:paddingEnd="32dp">


                <androidx.cardview.widget.CardView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/textView18"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:layout_marginBottom="8dp"
                            android:fontFamily="@font/poppins_semibold"
                            android:text="@string/title_full_name"
                            android:textSize="13dp" />
                        <RelativeLayout
                            android:layout_width="200dp"
                            android:layout_height="42dp"
                            android:background="@drawable/bg_password_field"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp"
                            android:gravity="center_vertical">
                            <EditText
                                android:id="@+id/edtFullname"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@android:color/transparent"
                                android:hint="Erik Le"
                                android:textColorHint="#808080"
                                android:textSize="15dp"
                                android:inputType="text"
                                android:focusable="false"
                                android:cursorVisible="false" />
                            <ImageView
                                android:id="@+id/ivEditName"
                                android:layout_width="16dp"
                                android:layout_height="16dp"
                                android:layout_alignParentEnd="true"
                                android:layout_centerVertical="true"
                                android:contentDescription="Toggle visibility"
                                android:src="@drawable/ic_pencil" />
                        </RelativeLayout>


                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <ImageView
                    android:id="@+id/user_ava"
                    android:layout_width="93dp"
                    android:layout_height="93dp"
                    android:layout_gravity="center_vertical"
                    android:layout_weight="1"
                    app:srcCompat="@drawable/profile_picture" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="32dp"
                android:paddingEnd="32dp"
                android:background="#ffffff">
                <!--email-->
                <TextView
                    android:id="@+id/textView2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:layout_marginBottom="8dp"
                    android:fontFamily="@font/poppins_semibold"
                    android:text="@string/title_email"
                    android:textSize="13dp" />
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="42dp"
                    android:background="@drawable/bg_password_field"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:gravity="center_vertical">

                    <EditText
                        android:id="@+id/edtMail"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@android:color/transparent"
                        android:hint="erikle@gmail.com"
                        android:textColorHint="#808080"
                        android:textSize="15dp"
                        android:inputType="none"
                        android:focusable="false"
                        android:cursorVisible="false" />

                    <ImageView
                        android:id="@+id/ivEditMail"
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:contentDescription="Toggle visibility"
                        android:src="@drawable/ic_pencil" />
                </RelativeLayout>

                <!--address-->
                <TextView
                    android:id="@+id/textView5"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:layout_marginBottom="8dp"
                    android:fontFamily="@font/poppins_semibold"
                    android:text="@string/title_address"
                    android:textSize="13dp" />
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="42dp"
                    android:background="@drawable/bg_password_field"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:gravity="center_vertical">

                    <EditText
                        android:id="@+id/edtAddress"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@android:color/transparent"
                        android:cursorVisible="false"
                        android:focusable="false"
                        android:hint="12 lê văn việt, Thủ Đức"
                        android:inputType="none"
                        android:textColorHint="#808080"
                        android:textSize="15dp" />

                    <ImageView
                        android:id="@+id/ivEditAddress"
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:contentDescription="Toggle visibility"
                        android:src="@drawable/ic_pencil" />
                </RelativeLayout>
                <!--gender-->
                <TextView
                    android:id="@+id/textView4"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:fontFamily="@font/poppins_semibold"
                    android:text="@string/title_gender"
                    android:textSize="13dp" />
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/genderLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint=""
                    app:boxBackgroundMode="none">

                    <AutoCompleteTextView
                        android:id="@+id/autoGender"
                        android:layout_width="match_parent"
                        android:layout_height="42dp"
                        android:background="@drawable/bg_password_field"
                        android:drawableEnd="@drawable/ic_arrow_down"
                        android:fontFamily="@font/poppins"
                        android:gravity="center_vertical"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:textColor="#808080"
                        android:textSize="15dp"
                        android:focusable="false"
                        android:cursorVisible="false" />


                </com.google.android.material.textfield.TextInputLayout>
                <!--address-->
                <TextView
                    android:id="@+id/textView3"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:layout_marginBottom="8dp"
                    android:fontFamily="@font/poppins_semibold"
                    android:text="@string/title_dob"
                    android:textSize="13dp" />
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="42dp"
                    android:background="@drawable/bg_password_field"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:gravity="center_vertical">

                    <EditText
                        android:id="@+id/edtDOB"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@android:color/transparent"
                        android:cursorVisible="false"
                        android:focusable="false"
                        android:hint="12/07/2004"
                        android:inputType="none"
                        android:textColorHint="#808080"
                        android:textSize="15dp" />

                    <ImageView
                        android:id="@+id/ivEditDOB"
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:contentDescription="Toggle visibility"
                        android:src="@drawable/ic_pencil" />
                </RelativeLayout>

            </LinearLayout>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:paddingStart="32dp"
                android:paddingEnd="32dp"
                android:gravity="center_vertical"
                android:layout_marginTop="20dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_change_password"
                    android:layout_width="45dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:text="@string/title_title_change_password"
                    android:fontFamily="@font/poppins"
                    android:textSize="15sp"
                    android:textColor="#0A7B41"
                    android:padding="0dp"
                    app:cornerRadius="0dp"
                    app:strokeColor="#0A7B41"
                    app:strokeWidth="1dp"
                    app:backgroundTint="#FFFFFF" />



                <View
                    android:layout_width="20dp"
                    android:layout_height="0dp"/>

                <Button
                    android:id="@+id/btn_profile_update"
                    android:layout_width="45dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:text="@string/title_btn_update"
                    app:cornerRadius="0dp"
                    android:backgroundTint="#0A7B41"
                    android:fontFamily="@font/poppins"
                    android:textSize="15dp"/>
            </LinearLayout>
            <!--view history-->

            <androidx.cardview.widget.CardView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@android:color/transparent"
                android:layout_gravity="center">

                <LinearLayout
                    android:layout_width="329dp"
                    android:layout_height="35dp"
                    android:orientation="horizontal"
                    android:background="#0A7B41"
                    android:padding="5dp"
                    android:paddingStart="32dp"
                    android:paddingEnd="32dp"
                    android:gravity="center_vertical">

                    <ImageView
                        android:id="@+id/imageView13"
                        android:layout_width="20dp"
                        android:layout_height="18dp"
                        app:srcCompat="@drawable/ic_3star" />

                    <TextView
                        android:id="@+id/textView51"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/title_order_history"
                        android:fontFamily="@font/poppins_semibold_italic"
                        android:textColor="#ffffff"
                        android:textSize="14dp"
                        android:layout_marginStart="10dp"
                        android:layout_weight="1"/>


                    <ImageView
                        android:id="@+id/imageView14"
                        android:layout_width="14dp"
                        android:layout_height="10dp"
                        app:srcCompat="@drawable/ic_arrow_right_white" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="32dp"
                android:paddingEnd="32dp">
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvSaleOrder"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:clipToPadding="false"
                    android:paddingBottom="16dp" />
            </LinearLayout>

            <androidx.cardview.widget.CardView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp"
                app:cardBackgroundColor="@android:color/transparent"
                android:layout_gravity="center">

                <LinearLayout
                    android:layout_width="329dp"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:background="#0A7B41"
                    android:padding="5dp"
                    android:paddingStart="32dp"
                    android:paddingEnd="32dp"
                    android:gravity="center_vertical">

                    <ImageView
                        android:id="@+id/imageView16"
                        android:layout_width="20dp"
                        android:layout_height="18dp"
                        app:srcCompat="@drawable/ic_3star" />

                    <TextView
                        android:id="@+id/textView52"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:fontFamily="@font/poppins_semibold_italic"
                        android:text="@string/title_interested_events"
                        android:textColor="#ffffff"
                        android:textSize="14dp"
                        android:layout_weight="1"/>


                    <ImageView
                        android:id="@+id/imageView15"
                        android:layout_width="14dp"
                        android:layout_height="10dp"
                        app:srcCompat="@drawable/ic_arrow_right_white" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="32dp"
                android:paddingEnd="32dp">
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvEvents"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:clipToPadding="false"
                    android:paddingBottom="16dp" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>